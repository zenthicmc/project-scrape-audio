# ============================================================
# ScriptAI — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/scriptai"

# ─── NextAuth ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google OAuth ───────────────────────────────────────────
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Claude AI (Anthropic) ──────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Redis (BullMQ) ─────────────────────────────────────────
# Local: redis://localhost:6379
# Railway: provided automatically
REDIS_URL="redis://localhost:6379"

# ─── SMTP (Email) ───────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="ScriptAI <noreply@scriptai.app>"

# ─── Midtrans Payment ───────────────────────────────────────
# Get from: https://dashboard.midtrans.com/
MIDTRANS_SERVER_KEY="SB-Mid-server-..."
MIDTRANS_CLIENT_KEY="SB-Mid-client-..."
MIDTRANS_IS_PRODUCTION="false"

# Frontend (exposed to browser)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-..."
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION="false"

# ─── App Config ─────────────────────────────────────────────
# Credits deducted per script generation
CREDITS_PER_GENERATION="10"

# ─── Optional: Owner Notification ───────────────────────────
# Webhook URL to notify owner of payments/errors
OWNER_NOTIFY_URL=""
